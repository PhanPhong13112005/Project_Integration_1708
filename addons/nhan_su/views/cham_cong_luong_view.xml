<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_cham_cong_tree" model="ir.ui.view">
            <field name="name">cham.cong.tree</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <tree string="Chấm công">
                    <field name="check_in"/>
                    <field name="nhan_vien_id"/>
                    <field name="so_gio_lam" widget="float_time"/>
                    <field name="cong_thuc_te"/>
                    <field name="di_muon"/>
                </tree>
            </field>
        </record>

        <record id="view_cham_cong_form" model="ir.ui.view">
            <field name="name">cham.cong.form</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group string="Thông tin chính">
                                <field name="nhan_vien_id"/>
                                <field name="check_in"/>
                                <field name="check_out"/>
                            </group>
                            <group string="Kết quả">
                                <field name="so_gio_lam" widget="float_time"/>
                                <field name="cong_thuc_te"/>
                                <field name="di_muon"/>
                                <field name="ve_som"/>
                            </group>
                        </group>
                        <field name="ghi_chu" placeholder="Ghi chú thêm..."/>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_bang_luong_tree" model="ir.ui.view">
            <field name="name">bang.luong.tree</field>
            <field name="model">bang_luong</field>
            <field name="arch" type="xml">
                <tree string="Bảng lương">
                    <field name="name"/>
                    <field name="nhan_vien_id"/>
                    <field name="tong_ngay_cong"/>
                    <field name="tong_thuc_linh" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                </tree>
            </field>
        </record>

        <record id="view_bang_luong_form" model="ir.ui.view">
            <field name="name">bang.luong.form</field>
            <field name="model">bang_luong</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group string="Kỳ lương">
                                <field name="nhan_vien_id"/>
                                <field name="thang"/>
                                <field name="nam"/>
                            </group>
                            <group string="Tổng hợp công">
                                <field name="tong_ngay_cong"/>
                                <field name="so_lan_di_muon"/>
                            </group>
                            <group string="Chi tiết lương">
                                <field name="luong_co_ban" widget="monetary"/>
                                <field name="tong_thuc_linh" widget="monetary" style="font-size: 16px; font-weight: bold; color: green;"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_cham_cong" model="ir.actions.act_window">
            <field name="name">Dữ liệu Chấm công</field>
            <field name="res_model">cham_cong</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="action_bang_luong" model="ir.actions.act_window">
            <field name="name">Bảng lương tháng</field>
            <field name="res_model">bang_luong</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_ql_cham_cong" 
                  name="Chấm công &amp; Lương"
                  parent="nhan_su.menu_root" 
                  sequence="20"/>

        <menuitem id="menu_action_cham_cong" 
                  name="Dữ liệu chấm công" 
                  parent="menu_ql_cham_cong" 
                  action="action_cham_cong" 
                  sequence="1"/>

        <menuitem id="menu_action_bang_luong" 
                  name="Bảng lương" 
                  parent="menu_ql_cham_cong" 
                  action="action_bang_luong" 
                  sequence="2"/>
    </data>
</odoo>