<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_du_bao_graph" model="ir.ui.view">
            <field name="name">ns.du.bao.graph</field>
            <field name="model">ns.du.bao</field>
            <field name="arch" type="xml">
                <graph string="Dự báo nghỉ việc" type="bar">
                    <field name="nhan_vien_id" type="row"/>
                    <field name="diem_rui_ro" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="view_du_bao_tree" model="ir.ui.view">
            <field name="name">ns.du.bao.tree</field>
            <field name="model">ns.du.bao</field>
            <field name="arch" type="xml">
                <tree string="Dự báo" decoration-danger="muc_do_canh_bao=='nguy_hiem'">
                    <header>
                        <button name="action_train_and_predict" type="object" string="🔄 Huấn luyện &amp; Dự báo AI" class="oe_highlight"/>
                    </header>
                    <field name="nhan_vien_id"/>
                    <field name="diem_rui_ro" widget="progressbar"/>
                    <field name="muc_do_canh_bao" widget="badge"/>
                </tree>
            </field>
        </record>

        <record id="view_du_bao_form" model="ir.ui.view">
            <field name="name">ns.du.bao.form</field>
            <field name="model">ns.du.bao</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_tu_dong_lay_du_lieu" string="🤖 Lấy số liệu Chấm công" type="object"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="nhan_vien_id"/>
                            <field name="so_gio_lam"/>
                            <field name="so_lan_muon"/>
                            <field name="diem_rui_ro" widget="progressbar"/>
                            <field name="phan_tich_chi_tiet"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_du_bao_nghi_viec" model="ir.actions.act_window">
            <field name="name">Dự báo Nghỉ việc</field>
            <field name="res_model">ns.du.bao</field>
            <field name="view_mode">graph,tree,form</field>
        </record>
    </data>
</odoo>