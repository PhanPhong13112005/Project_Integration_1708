<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_du_bao_graph" model="ir.ui.view">
            <field name="name">ns.du.bao.graph</field>
            <field name="model">ns.du.bao</field>
            <field name="arch" type="xml">
                <graph string="Biểu đồ Phân tích Rủi ro Nghỉ việc" type="bar">
                    <field name="nhan_vien_id" type="row"/>
                    <field name="diem_rui_ro" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="view_du_bao_tree" model="ir.ui.view">
            <field name="name">ns.du.bao.tree</field>
            <field name="model">ns.du.bao</field>
            <field name="arch" type="xml">
                <tree string="Danh sách dự báo" decoration-danger="muc_do_canh_bao=='nguy_hiem'" decoration-warning="muc_do_canh_bao=='canh_bao'">
                    <header>
                        <button name="action_chay_du_bao_hang_loat" type="object" string="🚀 AI Quét Dự báo Toàn bộ Công ty" class="btn-danger"/>
                    </header>
                    <field name="nhan_vien_id" widget="many2one_avatar"/>
                    <field name="so_gio_lam"/>
                    <field name="so_lan_muon"/>
                    <field name="diem_rui_ro" widget="progressbar" string="Tỷ lệ rủi ro (%)"/>
                    <field name="muc_do_canh_bao" widget="badge" 
                           attrs="{'decoration-success': [('muc_do_canh_bao', '=', 'an_toan')],
                                   'decoration-warning': [('muc_do_canh_bao', '=', 'canh_bao')],
                                   'decoration-danger': [('muc_do_canh_bao', '=', 'nguy_hiem')]}"/>
                </tree>
            </field>
        </record>

        <record id="view_du_bao_form" model="ir.ui.view">
            <field name="name">ns.du.bao.form</field>
            <field name="model">ns.du.bao</field>
            <field name="arch" type="xml">
                <form string="Hồ sơ phân tích AI">
                    <header>
                        <button name="action_tu_dong_lay_du_lieu" string="🤖 Lấy số liệu Chấm công" type="object" class="oe_highlight"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Dữ liệu đầu vào">
                                <field name="nhan_vien_id" options="{'no_create': True}"/>
                                <field name="so_gio_lam"/>
                                <field name="so_lan_muon"/>
                                <field name="nghi_khong_phep"/>
                            </group>
                            <group string="Kết quả AI">
                                <field name="diem_rui_ro" widget="progressbar"/>
                                <field name="muc_do_canh_bao" widget="badge" 
                                       attrs="{'decoration-success': [('muc_do_canh_bao', '=', 'an_toan')],
                                               'decoration-warning': [('muc_do_canh_bao', '=', 'canh_bao')],
                                               'decoration-danger': [('muc_do_canh_bao', '=', 'nguy_hiem')]}"/>
                                <field name="phan_tich_chi_tiet" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_du_bao_nghi_viec" model="ir.actions.act_window">
            <field name="name">AI Dự báo Nghỉ việc</field>
            <field name="res_model">ns.du.bao</field>
            <field name="view_mode">graph,tree,form</field>
        </record>
    </data>
</odoo>